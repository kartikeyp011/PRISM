# PRISM environment variables — copy to .env and adjust

# Remote LLM (from Kaggle ngrok notebook). Leave empty for mock mode.
LLM_BASE_URL=
LLM_MODEL=llama3.2

# Database
DATABASE_URL=postgresql+asyncpg://prism:prism@postgres:5432/prism

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_URL=http://chroma:8000

# Computer vision (optional — false = mock CV mode for demo)
CV_ENABLED=false
CV_MODEL=yolov8n.pt

# Postgres (used by docker-compose postgres service)
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism
POSTGRES_DB=prism
